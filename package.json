{
  "name": "github-dock",
  "private": true,
  "version": "0.1.0",
  "description": "Small desktop GitHub companion app for repository state, pull requests, issues, branches, and notifications.",
  "author": "Mohamed Ben Moussa",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:4173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:4173 electron .",
    "build": "tsc -b && vite build",
    "package:win": "npm run build && electron-builder --win portable",
    "preview": "vite preview",
    "start": "electron ."
  },
  "build": {
    "appId": "com.hyujnn.githubdock",
    "productName": "GitHub Dock",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        "portable"
      ],
      "signAndEditExecutable": false,
      "artifactName": "GitHub-Dock-${version}.${ext}"
    }
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@octokit/rest": "^22.0.1",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "^7.1.7",
    "wait-on": "^9.0.4"
  }
}